{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
{{- $pages := first 20 (where .Site.RegularPages "Section" "articles") -}}
{{- $feedURL := "" -}}
{{- with .OutputFormats.Get "RSS" }}{{ $feedURL = .Permalink }}{{ end -}}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Params.shortTitle | default .Site.Title | transform.XMLEscape | safeHTML }} Articles</title>
    <link>{{ .Site.BaseURL }}</link>
    <description>Recent articles about SpecDD, specification-driven development, AI coding agents, and implementation context.</description>
    <generator>Hugo</generator>
    <language>{{ .Site.LanguageCode }}</language>
    {{- with $feedURL }}
    <atom:link href="{{ . }}" rel="self" type="application/rss+xml" />
    {{- end }}
    {{- range $pages }}
    {{ partial "rss-item.xml" . }}
    {{- end }}
  </channel>
</rss>
